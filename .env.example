# Comma-separated email addresses for the daily newsletter
# Example: CLAUDEASHIAN_EMAIL_LIST=alice@example.com,bob@example.com
CLAUDEASHIAN_EMAIL_LIST=

# Resend API key for sending newsletters (https://resend.com/api-keys)
RESEND_KEY=

# From address for newsletters (requires a verified domain in Resend)
# Default: onboarding@resend.dev (test address — can only deliver to your Resend signup email)
CLAUDEASHIAN_FROM_EMAIL=onboarding@resend.dev
